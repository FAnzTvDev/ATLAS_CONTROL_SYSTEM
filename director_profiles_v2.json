{
  "gothic_institutional_slowburn": {
    "id": "gothic_institutional_slowburn",
    "label": "Institutional Gothic - Slowburn Horror",
    "logline": "Institutional gothic horror told with a patient, predator-like camera that makes architecture feel alive and people feel small.",
    "cinema_influences": [
      "Sicario",
      "Zodiac",
      "The Others"
    ],
    "influences": [
      {
        "film": "Sicario",
        "year": 2015,
        "director": "Denis Villeneuve",
        "dp": "Roger Deakins",
        "notes": "Patient camera, architecture as predator, institutional dread"
      },
      {
        "film": "Zodiac",
        "year": 2007,
        "director": "David Fincher",
        "dp": "Harris Savides",
        "notes": "Cold observation, procedural tension, detached POV"
      }
    ],
    "story_pov_policy": {
      "pov_mode": "mostly_objective",
      "subjective_probability": 0.3,
      "objective_probability": 0.7,
      "rules": [
        "On first entry to any major location, keep protagonist under 25% of frame area.",
        "Reserve tight CUs on protagonist's eyes for true decisions or revelations.",
        "Avoid explicit POV shots in Act I; let the building look at them first."
      ]
    },
    "global_aesthetic": {
      "tone": [
        "institutional",
        "gothic",
        "slow_burn",
        "predatory"
      ],
      "color": [
        "cool_white_fluorescent",
        "sodium_vapor_accents",
        "muted_blacks"
      ],
      "contrast": "medium_high",
      "grain": "subtle"
    },
    "camera_policy": {
      "preferred_focal_lengths_mm": [
        24,
        32,
        40
      ],
      "avoid_focal_lengths_mm": [
        85,
        135
      ],
      "shot_size_distribution": {
        "WS": 0.45,
        "MS": 0.35,
        "CU": 0.2,
        "ECU": 0.0
      },
      "movement_bias": {
        "static": 0.25,
        "slow_dolly": 0.55,
        "slow_pan_tilt": 0.2,
        "handheld": 0.0
      },
      "angle_bias": {
        "eye_level": 0.4,
        "slight_low": 0.4,
        "slight_high": 0.2,
        "dutch": 0.0
      },
      "frame_stability": 0.95
    },
    "shot_scale_profile": {
      "WS": 0.45,
      "MS": 0.35,
      "CU": 0.2,
      "ECU": 0.0
    },
    "camera_movement_profile": {
      "static": 0.25,
      "slow_dolly": 0.55,
      "slow_pan_tilt": 0.2,
      "handheld": 0.0
    },
    "lighting_policy": {
      "base_color_temp_K": 4100,
      "color_temp_variation_K": 250,
      "lighting_ratio_range": [
        1.8,
        2.4
      ],
      "contrast_bias": "medium_high",
      "palette_keywords": [
        "cool_white_fluorescent",
        "sodium_vapor_accents",
        "muted_blacks",
        "no_romantic_candlelight"
      ]
    },
    "coverage_policy": {
      "base_shot_density_factor": 1.0,
      "min_shots_low_complexity": 2,
      "max_shots_high_complexity": 9,
      "prefers_long_takes": true,
      "establishing_priority": "high",
      "reaction_shot_priority": "low",
      "insert_priority": "medium"
    },
    "rhythm_policy": {
      "linger_on_emotional_turn": 0.9,
      "average_shot_weight": 0.8,
      "pacing_style": "slow_burn",
      "pre_cut_hold_s": 0.5,
      "post_cut_hold_s": 0.5
    },
    "director_mindset_tokens": {
      "predator_threshold": 0.8,
      "shadows_closing_in": true,
      "viewer_as_prey": true,
      "architecture_as_character": true
    },
    "style_anchor": "grounded, cinematic, high_dynamic_range, subtle_grain, institutional_gothic",
    "composition_rules": {
      "grid": "rule_of_thirds",
      "wide_anchor": "subject_small_lower_third, architecture_dominant",
      "dialogue_two_hander": "balanced_two_shot_or_OTS",
      "threat": "subject_lower_frame, ceiling_weighted",
      "negative_space_bias": 0.7,
      "symmetry_bias": 0.3
    },
    "semantic_knobs": {
      "tension_increase": {
        "strategy": "move closer + lengthen holds + decrease movement",
        "shot_scale_shift": {
          "CU": 0.15,
          "WS": -0.15
        },
        "shot_length_multiplier": 1.2
      },
      "architecture_reveal": {
        "strategy": "wide establishing, slow dolly, keep characters tiny",
        "composition_override": "subject_under_25_percent_frame",
        "movement_override": "slow_dolly_in"
      }
    },
    "shot_length_profile": {
      "max_seconds": 45,
      "extended_take_probability": 0.15,
      "use_frame_stitching": true,
      "stitch_strategy": "last_frame_to_first",
      "max_segments": 3,
      "min_seconds": 6,
      "avg_seconds": 12
    }
  },
